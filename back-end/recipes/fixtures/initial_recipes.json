  {"model": "recipes.recipe", "pk": 3, "fields": {
    "name": "Poulet Rôti au Citron et aux Herbes",
    "description": "Un poulet rôti parfumé aux herbes de Provence et au citron, croustillant dehors et moelleux dedans.",
    "servings": 4,
    "prep_time": 10,
    "cook_time": 90,
    "created_at": "2026-01-01T00:00:00Z",
    "steps": [
      "Préchauffer le four à 200°C (thermostat 6-7).",
      "Mélanger l'huile d'olive, le jus d'un citron, les herbes de Provence, le sel et le poivre.",
